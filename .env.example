# Copie este arquivo para .env e preencha os valores
# NUNCA commitar o .env — ele contém segredos de produção

# ─── Flask ────────────────────────────────────────────────────────────────────
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=gere-uma-chave-segura-aqui
FLASK_APP=app
FLASK_ENV=production

# ─── Banco de Dados ───────────────────────────────────────────────────────────
# Railway provê DATABASE_URL automaticamente ao adicionar o plugin PostgreSQL
# Localmente: deixe em branco para usar SQLite (instance/obria.db)
DATABASE_URL=postgresql://user:senha@host:5432/railway

# ─── Seed Automático (primeiro deploy) ───────────────────────────────────────
# Cria a organização RIAL e o usuário admin se o banco estiver vazio
# Após o primeiro deploy, pode deixar em branco (seed-auto é idempotente)
ADMIN_EMAIL=admin@rial.com.br
ADMIN_PASSWORD=troque-esta-senha-forte
ADMIN_NOME=Administrador RIAL

# ─── Cloudflare R2 (Fase 0.3) ────────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=obria-storage
R2_PUBLIC_URL=https://<account>.r2.cloudflarestorage.com

# ─── Google Sheets API (Fase 1.1) ────────────────────────────────────────────
# Cole o JSON completo da service account entre aspas simples
GOOGLE_CREDENTIALS_JSON=
